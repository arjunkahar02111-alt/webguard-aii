# WebGuard AI — Environment Configuration
# Copy to .env and fill in your values

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=WebGuard AI
APP_ENV=development
SECRET_KEY=change-me-to-a-strong-random-secret-key
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=webguard

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://webguard-git-main-arjunkahar02111-alts-projects.vercel.app/"]

# ── Scan Settings ──────────────────────────────────────────────────────────────
MAX_SCAN_DEPTH=3
MAX_CONCURRENT_SCANS=10
SCAN_TIMEOUT_SECONDS=120
REQUEST_TIMEOUT_SECONDS=10
RATE_LIMIT_PER_MINUTE=10

# ── Safety ─────────────────────────────────────────────────────────────────────
# Always true — WebGuard AI only uses safe, observation-based scanning
SAFE_MODE=true
USER_AGENT=WebGuardAI/1.0 (security-scanner; safe-mode)
